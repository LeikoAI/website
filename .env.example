# Database - use Supabase connection string or any PostgreSQL
DATABASE_URI=postgresql://user:password@host:5432/database
# Or: DATABASE_URL=postgresql://...

# Payload secret - at least 32 characters
PAYLOAD_SECRET=your-secret-key-at-least-32-chars

# Draft mode secret - use any random string (at least 32 chars)
PAYLOAD_DRAFT_SECRET=your-draft-secret-key-at-least-32-chars

# Optional: for absolute URLs in server context
NEXT_PUBLIC_SITE_URL=http://localhost:3002
